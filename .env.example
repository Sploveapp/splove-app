# Supabase (à configurer pour le développement)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Edge Function `moderate-photo` — secrets dans le dashboard Supabase (pas VITE_) :
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY (injectés par la plateforme)
# SIGHTENGINE_API_USER=…
# SIGHTENGINE_API_SECRET=…
# Sans Sightengine : les photos passent en pending_review (sauf MODERATION_STUB_APPROVED=1 côté Edge, réservé au dev)

# Testeurs : bypass SPLove+ / paywalls côté app (aucune indication UI)
# VITE_BETA_MODE=true
