# Supabase (à configurer pour le développement)
# Dashboard → Authentication → URL Configuration : Site URL + Redirect URLs doivent
# inclure http://localhost:5173 et l’URL Render (pas d’ancien domaine Replit).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_APP_ENV=local
VITE_VERIFF_PUBLIC_KEY=

# Edge Function `moderate-photo` — secrets dans le dashboard Supabase (pas VITE_) :
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY (injectés par la plateforme)
# SIGHTENGINE_API_USER=…
# SIGHTENGINE_API_SECRET=…
# Sans Sightengine : les photos passent en pending_review (sauf MODERATION_STUB_APPROVED=1 côté Edge, réservé au dev)

# Bêta : Splove+ / paywalls non bloquants + message discret sur la page SPLove+
# VITE_BETA_MODE=true
